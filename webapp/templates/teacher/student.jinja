{% extends 'layout.jinja' %}
{% block head %}
<link rel="stylesheet" href="{{ url_for('static', filename='css/flatpickr.min.css') }}">
{% endblock %}
{% block header %}
<li class="breadcrumb-item">
  <a class="text-decoration-none" href="/teacher">
    Преподавательская
  </a>
</li>
<li class="breadcrumb-item active">
  {{ user.email }}
</li>
{% endblock %}

{% block main %}
<div class="row">
  <div class="col-12">
    <h5 class="card-title fw-bold mb-2">
      {{ user.email }}
    </h5>
    <h6 class="card-subtitle mb-3 text-muted">
      Идентификатор: {{ user.id }}.
      {% if user.unconfirmed_hash %}
        Адрес почты не подтверждён.
      {% else %}
        Адрес почты подтверждён.
      {% endif %}
      {% if user.provider == 'lks' %}
        Аккаунт связан с ЕСИА РТУ МИРЭА.
      {% endif %}
    </h6>
  </div>
  <div class="col-12">
    <form action="/teacher/student/{{ user.id }}/info" method="POST" class="w-100">
      <div class="row">
        <div class="col-md-6 mb-1">
          <b class="d-block mb-1">Группа</b>
          <select name="group" class="form-select">
            <option value="-1" {{ "selected='selected'" if group is none else "" }}>
              Не выбрана
            </option>
            {% for g in groups %}
              <option value="{{ g.id }}" {{ "selected='selected'" if g.id == group.id else "" }}>
                {{ g.title }}
              </option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-6 mb-1">
          <b class="d-block mb-1">Вариант</b>
          <select name="variant" class="form-select">
            <option value="-1" {{ "selected='selected'" if variant is none else "" }}>
              Не выбран
            </option>
            {% for v in variants %}
              <option value="{{ v.id }}" {{ "selected='selected'" if v.id == variant.id else "" }}>
                {{ v.id + 1 }}
              </option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-12">
          <div class="text-muted mb-2">
            Если установить значение "Не выбрано", студенту будет предложено выбрать группу или вариант самостоятельно.
          </div>
          <button type="submit" class="btn btn-outline-primary w-100 d-block mb-2">
            Сохранить группу и вариант
          </button>
        </div>
      </div>
    </form>
  </div>
  {% if enable_manual_password_change %}
  <div class="col-12">
    <b class="d-block">Пароль студента</b>
    <div class="text-muted">
      Пароль от аккаунта студента можно обновить вручную, если почтовый сервис недоступен.
    </div>
    <form action="/teacher/student/{{ user.id }}/password" method="POST" class="w-100">
      <div class="row">
        <div class="col-md-8 mb-2">
          <input name="password" type="password" class="form-control mb-2" placeholder="Пароль" />
          {% if password_form.password.errors %}
          <small class="d-block alert alert-danger">
            {% for error in password_form.password.errors %}
            <div>{{ error }}</div>
            {% endfor %}
          </small>
          {% endif %}
        </div>
        <div class="col-md-4 mb-2">
          {{ password_form.csrf_token }}
          <button type="submit" class="btn btn-outline-primary w-100 d-block mb-2">
            Сохранить пароль
          </button>
        </div>
      </div>
    </form>
  </div>
  {% endif %}
</div>
<div class="row mt-1">
  {% if overrides %}
  <div class="col-12">
    <b class="d-block mb-1">Продления сроков сдачи</b>
  </div>
  {% endif %}
  {% for override in overrides %}
  <div class="col-12">
    <div class="mb-2">
      Блок {{ override.block + 1 }}. Продлено до {{ override.deadline.strftime('%Y.%m.%d %H:%M') }}, причина: {{ override.reason or 'не указана' }}.
      <a class="text-decoration-none" href="/teacher/student/{{ user.id }}/override-deadline/{{ override.block }}/delete">
        Отменить продление
      </a>
    </div>
  </div>
  {% endfor %}
  <div class="col-12">
    <b class="d-block mb-1">Разрешить продление</b>
    <form action="/teacher/student/{{ user.id }}/override-deadline" method="POST">
      <select class="form-select mb-2" name="block" required>
        {% for block_ in blocks %}
        <option value="{{ block_.id }}">
          Блок {{ block_.id + 1}}. {{ block_.title }} +{{ block_.weight }}
        </option>
        {% endfor %}
      </select>
      <input name="deadline" type="text" id="deadline" class="form-control mb-2" placeholder="Выберите дату" required />
      <input name="reason" type="text" class="form-control mb-2" placeholder="Причина продления" required />
      <button type="submit" class="btn btn-outline-primary w-100 d-block mb-2">
        Разрешить продление
      </button>
    </form>
  </div>
</div>
<script src="{{ url_for('static', filename='js/flatpickr.min.js') }}"></script>
<script src="{{ url_for('static', filename='js/flatpickr.ru.min.js') }}"></script>
<script>
  var oneWeekFromNow = new Date();
  oneWeekFromNow.setHours(23);
  oneWeekFromNow.setMinutes(59);
  flatpickr("#deadline", {
    enableTime: true,
    dateFormat: "Y.m.d H:i",
    minDate: "today",
    locale: "ru",
    defaultDate: oneWeekFromNow,
    disableMobile: "true"
  });
</script>
{% endblock %}
